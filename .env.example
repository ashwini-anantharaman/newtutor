# ─── Client-safe (Vite — exposed as VITE_* only) ───
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Production only — your Render backend URL (no trailing slash)
# VITE_API_URL=https://your-service.onrender.com

# ─── Server-only — NEVER prefix with VITE_ or expose to browser ───
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=https://your-project.supabase.co

# Optional
PORT=3001
CLAUDE_MODEL=claude-sonnet-4-5-20250929
VOYAGE_MODEL=voyage-3

# Generative Manim API (https://github.com/marcelo-earth/generative-manim)
# Run locally: docker run -p 8080:8080 -e ANTHROPIC_API_KEY=... generative-manim-api
GENERATIVE_MANIM_API_URL=http://127.0.0.1:8080
GENERATIVE_MANIM_ENGINE=anthropic
# GENERATIVE_MANIM_MODEL=
GENERATIVE_MANIM_ASPECT_RATIO=16:9
GENERATIVE_MANIM_ENABLED=true

# Optional: reliable YouTube transcription fallback (https://transcriptapi.com)
# TRANSCRIPT_API_KEY=

# Optional: audio upload transcription via OpenAI Whisper (Notes/Audio sources)
# OPENAI_API_KEY=sk-...
